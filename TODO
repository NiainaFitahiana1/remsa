//models prisma 
model Year {
  id        Int      @id @default(autoincrement())
  year      Int      @unique
  months    Month[]
}

model Month {
  id          Int      @id @default(autoincrement())
  number      Int
  name        String
  theme       String
  bgColor     String
  textColor   String
  yearId      Int
  year        Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)
  days        Day[]
}

model Day {
  id            Int       @id @default(autoincrement())
  date          DateTime  // ex: 2025-01-01
  dayName       String    // ex: "Alahady", "Alarobia", "Alakamisy", etc.
  title         String?   // ex: "Paska", "Taom-baovao", "Sampana Sekoly Alahady"
  type          DayType   // fete, advent, normal
  monthId       Int
  month         Month     @relation(fields: [monthId], references: [id], onDelete: Cascade)
  readings      Reading[]
}

enum DayType {
  normal
  fete
  advent
}

model Reading {
  id          Int       @id @default(autoincrement())
  book        String    // ex: "Isa.", "Mat.", "Asa."
  chapter     String    // ex: "60", "2"
  verses      String    // ex: "1-6", "19-31", "4b-15"
  dayId       Int
  day         Day       @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

